{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bates Stamping Metadata Schema",
  "description": "Metadata schema for Bates stamping and document identification in JLAW forensic evidence",
  "version": "1.0",
  "type": "object",
  "required": ["case_id", "bates_prefix", "document_metadata"],
  "properties": {
    "case_id": {
      "type": "string",
      "description": "Unique case identifier",
      "pattern": "^CASE-[0-9]{4}-[0-9]{4}$",
      "examples": ["CASE-2024-0001"]
    },
    "case_name": {
      "type": "string",
      "description": "Human-readable case name",
      "examples": ["Nike Inc. (CIK 320187) - 2019 Forensic Analysis"]
    },
    "bates_prefix": {
      "type": "string",
      "description": "Bates number prefix (typically party designation)",
      "pattern": "^[A-Z]{2,10}$",
      "examples": ["JLAW", "PLAINTIFF", "DEFENDANT", "DOJ"]
    },
    "bates_start_number": {
      "type": "integer",
      "description": "Starting Bates number for this case",
      "minimum": 1,
      "examples": [1, 1000]
    },
    "bates_format": {
      "type": "string",
      "description": "Bates number format template",
      "examples": [
        "{prefix}-{number:07d}",
        "{prefix}-{case_id}-{number:07d}",
        "{prefix}-{date}-{number:05d}"
      ]
    },
    "document_metadata": {
      "type": "array",
      "description": "Array of documents with Bates number assignments",
      "items": {
        "type": "object",
        "required": ["document_id", "bates_number", "page_range"],
        "properties": {
          "document_id": {
            "type": "string",
            "description": "Unique document identifier",
            "examples": ["E001", "DOC-0001234"]
          },
          "document_type": {
            "type": "string",
            "description": "SEC filing type or document category",
            "enum": [
              "10-K",
              "10-Q",
              "8-K",
              "Form 4",
              "DEF 14A",
              "13F-HR",
              "SC 13D",
              "SC 13G",
              "Form 144",
              "Dossier",
              "Chain of Custody",
              "Affidavit",
              "Other"
            ]
          },
          "source": {
            "type": "object",
            "description": "Document source information",
            "properties": {
              "system": {
                "type": "string",
                "description": "Source system",
                "examples": ["SEC EDGAR", "JLAW Generated", "External Submission"]
              },
              "accession_number": {
                "type": "string",
                "description": "SEC accession number (if applicable)",
                "pattern": "^[0-9]{10}-[0-9]{2}-[0-9]{6}$",
                "examples": ["0001234567-19-000001"]
              },
              "filing_date": {
                "type": "string",
                "format": "date",
                "description": "SEC filing date (ISO 8601)",
                "examples": ["2019-10-30"]
              },
              "acquisition_date": {
                "type": "string",
                "format": "date-time",
                "description": "Date/time document acquired by JLAW",
                "examples": ["2024-12-29T10:15:30Z"]
              }
            }
          },
          "bates_number": {
            "type": "object",
            "description": "Bates number assignment for this document",
            "required": ["start", "end"],
            "properties": {
              "start": {
                "type": "string",
                "description": "First Bates number for this document",
                "examples": ["JLAW-0000001", "PLAINTIFF-2024-0001000"]
              },
              "end": {
                "type": "string",
                "description": "Last Bates number for this document",
                "examples": ["JLAW-0000050", "PLAINTIFF-2024-0001049"]
              }
            }
          },
          "page_range": {
            "type": "object",
            "description": "Page range within document",
            "required": ["start_page", "end_page", "total_pages"],
            "properties": {
              "start_page": {
                "type": "integer",
                "description": "First page number",
                "minimum": 1,
                "examples": [1]
              },
              "end_page": {
                "type": "integer",
                "description": "Last page number",
                "minimum": 1,
                "examples": [50]
              },
              "total_pages": {
                "type": "integer",
                "description": "Total number of pages",
                "minimum": 1,
                "examples": [50]
              }
            }
          },
          "page_level_bates": {
            "type": "array",
            "description": "Page-by-page Bates number mapping (optional, for detailed tracking)",
            "items": {
              "type": "object",
              "required": ["page_number", "bates_number"],
              "properties": {
                "page_number": {
                  "type": "integer",
                  "description": "Page number within document",
                  "minimum": 1
                },
                "bates_number": {
                  "type": "string",
                  "description": "Bates number for this page"
                },
                "image_hash": {
                  "type": "string",
                  "description": "SHA-256 hash of page image (for integrity)",
                  "pattern": "^[a-f0-9]{64}$"
                }
              }
            }
          },
          "cross_references": {
            "type": "array",
            "description": "Cross-references to related documents",
            "items": {
              "type": "object",
              "properties": {
                "related_document_id": {
                  "type": "string",
                  "description": "Document ID of related document"
                },
                "relationship": {
                  "type": "string",
                  "description": "Type of relationship",
                  "enum": [
                    "attachment",
                    "exhibit",
                    "referenced_in",
                    "amendment",
                    "supersedes",
                    "superseded_by"
                  ]
                },
                "related_bates_range": {
                  "type": "string",
                  "description": "Bates range of related document",
                  "examples": ["JLAW-0000100 to JLAW-0000150"]
                }
              }
            }
          },
          "confidentiality": {
            "type": "object",
            "description": "Confidentiality designation",
            "properties": {
              "level": {
                "type": "string",
                "description": "Confidentiality level",
                "enum": [
                  "Public",
                  "Confidential",
                  "Highly Confidential - Attorneys' Eyes Only",
                  "Source Code"
                ]
              },
              "protective_order": {
                "type": "string",
                "description": "Protective order reference (if applicable)"
              }
            }
          },
          "hash_values": {
            "type": "object",
            "description": "Cryptographic hash values for integrity verification",
            "properties": {
              "sha256": {
                "type": "string",
                "description": "SHA-256 hash of document",
                "pattern": "^[a-f0-9]{64}$"
              },
              "sha3_512": {
                "type": "string",
                "description": "SHA3-512 hash of document",
                "pattern": "^[a-f0-9]{128}$"
              },
              "blake2b": {
                "type": "string",
                "description": "BLAKE2b hash of document",
                "pattern": "^[a-f0-9]{128}$"
              }
            }
          },
          "timestamp": {
            "type": "object",
            "description": "RFC 3161 timestamp information",
            "properties": {
              "timestamp_authority": {
                "type": "string",
                "description": "Timestamp authority URL",
                "examples": ["https://freetsa.org/tsr"]
              },
              "timestamp_token": {
                "type": "string",
                "description": "Base64-encoded RFC 3161 timestamp token"
              },
              "timestamp_datetime": {
                "type": "string",
                "format": "date-time",
                "description": "Timestamp date/time (ISO 8601)"
              }
            }
          },
          "production_notes": {
            "type": "string",
            "description": "Notes about document production (redactions, privilege, etc.)"
          }
        }
      }
    },
    "index_metadata": {
      "type": "object",
      "description": "Index and cross-reference information",
      "properties": {
        "total_documents": {
          "type": "integer",
          "description": "Total number of documents in case",
          "minimum": 0
        },
        "total_pages": {
          "type": "integer",
          "description": "Total number of pages across all documents",
          "minimum": 0
        },
        "bates_range": {
          "type": "object",
          "description": "Overall Bates range for case",
          "properties": {
            "start": {
              "type": "string",
              "description": "First Bates number in case"
            },
            "end": {
              "type": "string",
              "description": "Last Bates number in case"
            }
          }
        },
        "document_types_summary": {
          "type": "object",
          "description": "Count of documents by type",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          },
          "examples": [
            {
              "10-K": 1,
              "10-Q": 3,
              "Form 4": 12,
              "DEF 14A": 1
            }
          ]
        }
      }
    },
    "production_metadata": {
      "type": "object",
      "description": "Document production information",
      "properties": {
        "production_date": {
          "type": "string",
          "format": "date",
          "description": "Date documents produced"
        },
        "producing_party": {
          "type": "string",
          "description": "Party producing documents",
          "examples": ["JLAW Forensics", "Plaintiff", "Defendant"]
        },
        "receiving_party": {
          "type": "string",
          "description": "Party receiving documents"
        },
        "production_method": {
          "type": "string",
          "description": "Method of production",
          "enum": ["Electronic", "Paper", "Hybrid"]
        },
        "cover_letter": {
          "type": "string",
          "description": "Reference to cover letter or transmittal"
        }
      }
    },
    "audit_trail": {
      "type": "array",
      "description": "Audit trail of Bates stamping operations",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Date/time of operation"
          },
          "user": {
            "type": "string",
            "description": "User who performed operation"
          },
          "operation": {
            "type": "string",
            "description": "Type of operation",
            "enum": ["Bates Assigned", "Bates Modified", "Document Added", "Document Removed", "Index Generated"]
          },
          "details": {
            "type": "string",
            "description": "Additional details about operation"
          }
        }
      }
    }
  },
  "examples": [
    {
      "case_id": "CASE-2024-0001",
      "case_name": "Nike Inc. (CIK 320187) - 2019 Forensic Analysis",
      "bates_prefix": "JLAW",
      "bates_start_number": 1,
      "bates_format": "{prefix}-{number:07d}",
      "document_metadata": [
        {
          "document_id": "E001",
          "document_type": "10-K",
          "source": {
            "system": "SEC EDGAR",
            "accession_number": "0001234567-19-000001",
            "filing_date": "2019-10-30",
            "acquisition_date": "2024-12-29T10:15:30Z"
          },
          "bates_number": {
            "start": "JLAW-0000001",
            "end": "JLAW-0000150"
          },
          "page_range": {
            "start_page": 1,
            "end_page": 150,
            "total_pages": 150
          },
          "confidentiality": {
            "level": "Public"
          },
          "hash_values": {
            "sha256": "a3f5b8c9d2e7f1a4b6c8d9e0f2a3b5c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3"
          }
        },
        {
          "document_id": "E002",
          "document_type": "Form 4",
          "source": {
            "system": "SEC EDGAR",
            "accession_number": "0001234567-19-000012",
            "filing_date": "2019-06-15",
            "acquisition_date": "2024-12-29T10:20:45Z"
          },
          "bates_number": {
            "start": "JLAW-0000151",
            "end": "JLAW-0000153"
          },
          "page_range": {
            "start_page": 1,
            "end_page": 3,
            "total_pages": 3
          },
          "cross_references": [
            {
              "related_document_id": "E001",
              "relationship": "referenced_in",
              "related_bates_range": "JLAW-0000001 to JLAW-0000150"
            }
          ],
          "confidentiality": {
            "level": "Public"
          },
          "hash_values": {
            "sha256": "b4c6d8e0f2a4b6c8d0e2f4a6b8c0d2e4f6a8b0c2d4e6f8a0b2c4d6e8f0a2b4c6"
          }
        }
      ],
      "index_metadata": {
        "total_documents": 25,
        "total_pages": 1250,
        "bates_range": {
          "start": "JLAW-0000001",
          "end": "JLAW-0001250"
        },
        "document_types_summary": {
          "10-K": 1,
          "10-Q": 3,
          "8-K": 5,
          "Form 4": 12,
          "DEF 14A": 1,
          "Dossier": 1,
          "Chain of Custody": 1,
          "Affidavit": 1
        }
      },
      "production_metadata": {
        "production_date": "2024-12-29",
        "producing_party": "JLAW Forensics",
        "receiving_party": "U.S. Department of Justice",
        "production_method": "Electronic"
      }
    }
  ]
}
