# ════════════════════════════════════════════════════════════════
# JLAW FORENSIC ANALYSIS PLATFORM - ENVIRONMENT CONFIGURATION
# ════════════════════════════════════════════════════════════════
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to `.env` in the same directory
# 2. Replace placeholder values with your actual API keys
# 3. NEVER commit .env to git (it's already in .gitignore)
#
# For automatic key injection on clone, see: docs/API_SETUP_GUIDE.md
# ════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────
# P0 CRITICAL DEPENDENCIES (REQUIRED)
# ────────────────────────────────────────────────────────────────

# SEC EDGAR API Configuration
# SEC requires a User-Agent header with your organization name and contact email.
# See: https://www.sec.gov/os/accessing-edgar-data
# IMPORTANT: Replace with YOUR actual information or API requests will fail with HTTP 429
# Format: "CompanyName/1.0 (admin@company.com)" or "ProjectName contact@university.edu"
SEC_USER_AGENT="YourCompany/1.0 (your-email@company.com)"

# AI Providers (Dual Validation - BOTH REQUIRED)
# Anthropic API Key - REQUIRED for Claude cross-validation
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-api03-YOUR_ANTHROPIC_KEY_HERE"

# OpenAI API Key - REQUIRED for GPT-4 cross-validation
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-YOUR_OPENAI_API_KEY_HERE"

# ────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ────────────────────────────────────────────────────────────────

# PostgreSQL (Evidence Storage)
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
POSTGRES_DB="jlaw_evidence"
POSTGRES_USER="jlaw"
POSTGRES_PASSWORD="CHANGE_ME_SECURE_PASSWORD"

# Alternative: Full PostgreSQL URI
# TIMESCALEDB_URI="postgresql://jlaw:CHANGE_ME_SECURE_PASSWORD@localhost:5432/jlaw_forensics"
TIMESCALE_HOST="localhost"
TIMESCALE_PORT="5432"
TIMESCALE_DATABASE="jlaw_forensics"
TIMESCALE_USER="jlaw"
TIMESCALE_PASSWORD="CHANGE_ME_SECURE_TIMESCALE_PASSWORD"

# Redis (Caching & Rate Limiting)
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""  # Optional - leave empty for no auth
REDIS_DB="0"
REDIS_MAX_CONNECTIONS="50"
REDIS_SOCKET_TIMEOUT="30"
REDIS_SOCKET_CONNECT_TIMEOUT="10"

# Alternative: Full Redis URI
# REDIS_URI="redis://localhost:6379/0"

# Neo4j (Graph Database - Executive Networks)
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="CHANGE_ME_SECURE_NEO4J_PASSWORD"
NEO4J_DATABASE="neo4j"

# ────────────────────────────────────────────────────────────────
# OPTIONAL SERVICES
# ────────────────────────────────────────────────────────────────

# Polygon.io (Market Data - Optional)
# Get your key: https://polygon.io/dashboard/api-keys
# Used for: Market correlation analysis (Node 15)
# Without this key: Node 15 will be skipped
POLYGON_API_KEY=""

# OpenRouter (Multi-model access - Optional)
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# GovInfo API (Statutory citation validation - Optional)
# Get your key: https://api.govinfo.gov/docs/
GOVINFO_API_KEY=""

# ────────────────────────────────────────────────────────────────
# SEC EDGAR BULLETPROOF CONFIGURATION
# ────────────────────────────────────────────────────────────────

# Rate Limiting (conservative for 100% reliability)
SEC_RATE_LIMIT="6.0"  # requests per second (SEC allows 10, we use 6 for reliability)

# Caching
SEC_CACHE_ENABLED="true"
SEC_CACHE_DIR=".jlaw_cache/sec_edgar"
SEC_STALE_CACHE_FALLBACK="true"  # Use expired cache if fetch fails (crucial for reliability)

# Retry Configuration
SEC_MAX_RETRIES="5"
SEC_RETRY_STRATEGY="exponential"  # exponential|linear|fibonacci

# Circuit Breaker
SEC_CIRCUIT_BREAKER_ENABLED="true"

# Error Handling (graceful degradation)
SEC_RAISE_ON_FINAL_FAILURE="false"  # Return None instead of raising on final failure

# Mock Mode (testing without real API calls)
# SEC_MOCK_MODE="false"

# ────────────────────────────────────────────────────────────────
# SYSTEM CONFIGURATION
# ────────────────────────────────────────────────────────────────

# Execution Mode
STRICT_MODE="true"   # true = abort on gate failure, false = continue with warnings
AUTO_MODE="true"     # true = non-interactive, false = prompt for confirmations

# Performance Tuning
MAX_CONCURRENT_REQUESTS="5"  # SEC EDGAR rate limit compliance
REQUEST_DELAY_MS="100"       # Delay between SEC requests (ms)
CACHE_TTL_HOURS="24"         # Redis cache expiration

# Output Configuration
OUTPUT_DIR="output"
EVIDENCE_DIR="evidence"
REPORTS_DIR="reports"

# ────────────────────────────────────────────────────────────────
# LOGGING CONFIGURATION
# ────────────────────────────────────────────────────────────────

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL="INFO"

# Log format: 'json' for structured logging, 'text' for human-readable
# JSON format recommended for production and log aggregation systems
LOG_FORMAT="text"

# Log file paths
LOG_FILE="logs/jlaw.log"
AUDIT_LOG_FILE="logs/audit.log"

# Log rotation
LOG_ROTATION_MAX_BYTES="104857600"  # 100MB
LOG_ROTATION_BACKUP_COUNT="10"

# Structured Logging
STRUCTURED_LOGGING="true"  # Use structlog for JSON logs

# ────────────────────────────────────────────────────────────────
# SECURITY & COMPLIANCE
# ────────────────────────────────────────────────────────────────

# Evidence Chain Configuration
ENABLE_TRIPLE_HASH="true"      # SHA-256 + SHA3-512 + BLAKE2b
ENABLE_MERKLE_TREE="true"      # RFC 6962 compliant
ENABLE_RFC3161_TIMESTAMP="true"  # Cryptographic timestamps

# RFC 3161 Timestamp Authority
# COURT ADMISSIBILITY WARNING:
# - Network timestamps (FreeTSA) are court-admissible under FRE 902(13)/(14)
# - Local timestamps are NOT court-admissible for legal proceedings
# - For DOJ-grade forensic reports, always use a network timestamp authority
RFC3161_TIMESTAMP_URL="https://freetsa.org/tsr"
RFC3161_CERTIFICATE_PATH=""
RFC3161_HASH_ALGORITHM="sha256"

# Alternative timestamp authorities:
# - DigiCert: http://timestamp.digicert.com
# - Comodo: http://timestamp.comodoca.com/rfc3161
# - GlobalSign: http://timestamp.globalsign.com/scripts/timstamp.dll

# For testing ONLY (NOT court-admissible):
# RFC3161_TIMESTAMP_URL="local"

# Audit Logging
AUDIT_LOG_ENABLED="true"
AUDIT_LOG_RETENTION_DAYS="2555"  # 7 years (legal requirement)

# ────────────────────────────────────────────────────────────────
# AI MODEL CONFIGURATION
# ────────────────────────────────────────────────────────────────

# Default AI model to use
DEFAULT_AI_MODEL="claude-3-opus-20240229"

# Enable/disable dual-agent mode
DUAL_AGENT_MODE="false"

# Secondary OpenAI key (optional, for dual-agent mode)
OPENAI_SECONDARY_API_KEY=""

