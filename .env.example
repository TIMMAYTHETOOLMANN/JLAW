# ============================================================================
# JLAW SEC FORENSIC ANALYZER - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to `.env` in the same directory
# 2. Replace placeholder values with your actual API keys
# 3. NEVER commit .env to git (it's already in .gitignore)
#
# For automatic key injection on clone, see: docs/API_SETUP_GUIDE.md
# ============================================================================

# ============================================================================
# OPENAI CONFIGURATION
# ============================================================================
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE

# Secondary OpenAI key (optional, for dual-agent mode)
OPENAI_SECONDARY_API_KEY=sk-proj-YOUR_SECONDARY_OPENAI_KEY_HERE

# ============================================================================
# ANTHROPIC CONFIGURATION (Claude API)
# ============================================================================
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_ANTHROPIC_KEY_HERE

# ============================================================================
# OPENROUTER CONFIGURATION (Multi-model access)
# ============================================================================
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY_HERE

# ============================================================================
# GOVERNMENT DATA SOURCES
# ============================================================================
# GovInfo API Key: https://api.govinfo.gov/docs/
GOVINFO_API_KEY=YOUR_GOVINFO_API_KEY_HERE

# SEC EDGAR Configuration (Required - use your org info)
SEC_USER_AGENT=YourProject contact@your-email.org

# ============================================================================
# OPTIONAL CONFIGURATIONS
# ============================================================================
# Default AI model to use (claude-3-opus, gpt-4, etc.)
DEFAULT_AI_MODEL=claude-3-opus-20240229

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable/disable dual-agent mode
DUAL_AGENT_MODE=false

