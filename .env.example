# ============================================================================
# JLAW SEC FORENSIC ANALYZER - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to `.env` in the same directory
# 2. Replace placeholder values with your actual API keys
# 3. NEVER commit .env to git (it's already in .gitignore)
#
# For automatic key injection on clone, see: docs/API_SETUP_GUIDE.md
# ============================================================================

# ============================================================================
# OPENAI CONFIGURATION
# ============================================================================
# OpenAI API Key - REQUIRED for primary AI agent validation
# Get your key: https://platform.openai.com/api-keys
# Format: sk-proj-... or sk-...
# Used for: GPT-4 forensic analysis, pattern detection, dual-agent validation
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE

# Secondary OpenAI key (optional, for dual-agent mode)
OPENAI_SECONDARY_API_KEY=sk-proj-YOUR_SECONDARY_OPENAI_KEY_HERE

# ============================================================================
# ANTHROPIC CONFIGURATION (Claude API)
# ============================================================================
# Anthropic API Key - REQUIRED for secondary AI agent validation
# Get your key: https://console.anthropic.com/settings/keys
# Format: sk-ant-...
# Used for: Claude forensic analysis, cross-validation, consensus scoring
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_ANTHROPIC_KEY_HERE

# ============================================================================
# OPENROUTER CONFIGURATION (Multi-model access)
# ============================================================================
# OpenRouter API Key - OPTIONAL alternative AI provider
# Get your key: https://openrouter.ai/keys
# Format: sk-or-v1-...
# Used for: Multi-model AI access (fallback option)
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY_HERE

# ============================================================================
# GOVERNMENT DATA SOURCES
# ============================================================================
# GovInfo API Key - OPTIONAL for live statutory citation validation
# Get your key: https://api.govinfo.gov/docs/
# Used for: Real-time validation of USC, CFR, and Pub.L. citations
# Without this key: Static citation references will be used
GOVINFO_API_KEY=YOUR_GOVINFO_API_KEY_HERE

# ============================================================================
# SEC EDGAR Configuration (REQUIRED for SEC API access)
# ============================================================================
# SEC requires a User-Agent header with your organization name and contact email.
# See: https://www.sec.gov/os/accessing-edgar-data
#
# IMPORTANT: Replace with YOUR actual information:
#   - Include your company/project name
#   - Include a valid contact email
#   - Do NOT use the placeholder below - API requests will fail with HTTP 429
#
# Format examples:
#   CompanyName/1.0 (admin@company.com)
#   ProjectName contact@university.edu
#   Organization/Version (support@organization.org)
#
# Mock mode (testing without real API calls):
#   SEC_MOCK_MODE=true
#
SEC_USER_AGENT=YourCompany/1.0 (your-email@company.com)
# SEC_MOCK_MODE=false

# ============================================================================
# SEC EDGAR Bulletproof Configuration (v4.1.0)
# ============================================================================
# Enhanced SEC EDGAR client with advanced reliability features:
#   - Persistent caching with stale fallback
#   - Adaptive rate limiting
#   - Circuit breaker protection
#   - Multiple retry strategies

# Rate Limiting (conservative for 100% reliability)
SEC_RATE_LIMIT=6.0  # requests per second (SEC allows 10, we use 6 for reliability)

# Caching
SEC_CACHE_ENABLED=true
SEC_CACHE_DIR=.jlaw_cache/sec_edgar
SEC_STALE_CACHE_FALLBACK=true  # Use expired cache if fetch fails (crucial for reliability)

# Retry Configuration
SEC_MAX_RETRIES=5
SEC_RETRY_STRATEGY=exponential  # exponential|linear|fibonacci

# Circuit Breaker
SEC_CIRCUIT_BREAKER_ENABLED=true

# Error Handling (graceful degradation)
SEC_RAISE_ON_FINAL_FAILURE=false  # Return None instead of raising on final failure

# ============================================================================
# MARKET DATA & FINANCIAL APIS
# ============================================================================
# Polygon.io API Key - OPTIONAL for real-time market data (Node 15)
# Get your key: https://polygon.io/dashboard/api-keys
# Used for: Market correlation analysis, stock price data, trading volumes
# Without this key: Node 15 (Market Correlation Engine) will be skipped
POLYGON_API_KEY=YOUR_POLYGON_API_KEY_HERE

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Neo4j Graph Database (Node 11 - Executive Network Mapping)
# Used for: Executive network analysis, board interlocks, compensation networks
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_SECURE_NEO4J_PASSWORD
NEO4J_DATABASE=neo4j

# TimescaleDB Configuration (Time-series financial data)
# Used for: Financial metrics time-series, market data correlation, temporal analysis
# Format: postgresql://username:password@host:port/database
TIMESCALEDB_URI=postgresql://jlaw:CHANGE_ME_SECURE_TIMESCALE_PASSWORD@localhost:5432/jlaw_forensics
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_DATABASE=jlaw_forensics
TIMESCALE_USER=jlaw
TIMESCALE_PASSWORD=CHANGE_ME_SECURE_TIMESCALE_PASSWORD

# Redis Configuration (Caching and rate limiting)
# Used for: SEC API rate limiting, response caching, session management
REDIS_URI=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=30
REDIS_SOCKET_CONNECT_TIMEOUT=10

# ============================================================================
# TIMESTAMP & EVIDENCE CHAIN
# ============================================================================
# RFC3161 Timestamp Server for evidence chain integrity
# 
# COURT ADMISSIBILITY WARNING:
# - Network timestamps (FreeTSA) are court-admissible under FRE 902(13)/(14)
# - Local timestamps are NOT court-admissible for legal proceedings
# - For DOJ-grade forensic reports, always use a network timestamp authority
# 
# Default: FreeTSA public timestamp server (court-admissible)
RFC3161_TIMESTAMP_URL=https://freetsa.org/tsr
RFC3161_CERTIFICATE_PATH=
RFC3161_HASH_ALGORITHM=sha256
# 
# Alternative timestamp authorities:
# - DigiCert: http://timestamp.digicert.com
# - Comodo: http://timestamp.comodoca.com/rfc3161
# - GlobalSign: http://timestamp.globalsign.com/scripts/timstamp.dll
# 
# For testing ONLY (NOT court-admissible):
# RFC3161_TIMESTAMP_URL=local

# ============================================================================
# OPTIONAL CONFIGURATIONS
# ============================================================================
# Default AI model to use (claude-3-opus, gpt-4, etc.)
DEFAULT_AI_MODEL=claude-3-opus-20240229

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable/disable dual-agent mode
DUAL_AGENT_MODE=false

