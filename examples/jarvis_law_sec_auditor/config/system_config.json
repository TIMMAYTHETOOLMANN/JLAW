{
  "system": {
    "name": "JARVIS:LAW Forensic Analysis Platform",
    "version": "2.0-ENHANCED",
    "classification": "FORENSIC GRADE",
    "status": "PRODUCTION"
  },

  "core_modules": {
    "mandatory": true,
    "description": "Core enhancement modules are REQUIRED for all analyses",

    "module_1_zero_dollar_detector": {
      "enabled": true,
      "mandatory": true,
      "name": "Zero-Dollar Pattern Amplifier",
      "threshold_high_risk_shares": 20000,
      "threshold_medium_risk_shares": 10000,
      "severity_levels": ["HIGH", "MEDIUM"],
      "purpose": "Detects excessive zero-cost equity compensation and gift transfers"
    },

    "module_2_10b5_1_compliance": {
      "enabled": true,
      "mandatory": true,
      "name": "10b5-1 Trading Plan Compliance Verifier",
      "cooling_off_days_officer": 90,
      "cooling_off_days_other": 30,
      "check_consistency": true,
      "purpose": "Verifies proper adoption and execution of Rule 10b5-1 trading plans"
    },

    "module_3_risk_weighting": {
      "enabled": true,
      "mandatory": true,
      "name": "Insider Role Risk Weighting",
      "risk_multipliers": {
        "CEO": 1.5,
        "CFO": 1.4,
        "COO": 1.3,
        "CHAIRMAN": 1.5,
        "PRESIDENT": 1.4,
        "DIRECTOR": 1.2,
        "OFFICER": 1.3,
        "EVP": 1.2,
        "SVP": 1.15,
        "VP": 1.1
      },
      "purpose": "Amplifies risk scores based on insider role and access to MNPI"
    },

    "module_4_earnings_correlation": {
      "enabled": true,
      "mandatory": true,
      "name": "Earnings Event Correlator",
      "window_days": 14,
      "critical_window_days": 7,
      "cluster_threshold": 2,
      "purpose": "Detects trading activity correlated with earnings announcements"
    }
  },

  "data_quality": {
    "zero_tolerance": true,
    "require_complete_extraction": true,
    "no_placeholders": true,
    "no_na_values": true,
    "minimum_fields_per_transaction": [
      "transaction_date",
      "transaction_code",
      "shares",
      "price_per_share",
      "acquired_disposed",
      "shares_owned_after",
      "direct_indirect"
    ]
  },

  "analysis_standards": {
    "forensic_grade": true,
    "evidentiary_quality": true,
    "chain_of_custody": true,
    "human_readable_reports": true,
    "machine_readable_json": true,
    "visual_analytics": true
  },

  "enforcement": {
    "module_validation_required": true,
    "fail_if_module_unavailable": true,
    "warn_if_incomplete_data": true,
    "halt_on_critical_errors": true
  },

  "reporting": {
    "include_enhancement_flags": true,
    "include_risk_rankings": true,
    "include_earnings_correlation": true,
    "include_compliance_findings": true,
    "separate_module_sections": true
  },

  "deployment": {
    "environment": "production",
    "scalable": true,
    "batch_processing": true,
    "single_file_analysis": true,
    "supports_thousands_of_filings": true
  },

  "_metadata": {
    "created": "2025-11-09",
    "last_updated": "2025-11-09",
    "author": "JARVIS:LAW Enhancement Integration System",
    "description": "Core configuration for enhanced forensic analysis system with mandatory detection modules"
  }
}

