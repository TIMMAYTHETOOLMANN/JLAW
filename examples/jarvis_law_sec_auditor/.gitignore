# Git Ignore - Black Site Protocol
# Prevent sensitive API keys from being committed

# Environment Configuration
.env
.env.local
.env.production
.env.development

# API Keys
**/api_keys.txt
**/secrets.json
**/*.key

# Evidence Chain (contains sensitive filing data)
memory/sec_filings_archive/
memory/evidence_chain/
memory/sec_filings/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# Temporary files
*.tmp
*.temp

