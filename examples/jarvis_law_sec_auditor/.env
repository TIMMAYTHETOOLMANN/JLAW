# JARVIS:LAW Black Site Protocol - Environment Configuration
# DO NOT COMMIT THIS FILE TO VERSION CONTROL
# ADD YOUR KEYS MANUALLY AFTER CLONING - NEVER COMMIT ACTUAL KEYS

# OpenAI API Configuration
OPENAI_API_KEY=

# GovInfo API Configuration (also works with SEC EDGAR Online)
GOVINFO_API_KEY=
SEC_EDGAR_API_KEY=

# User Agent for SEC.gov requests (required by SEC)
SEC_USER_AGENT=JLAW Forensics System contact@your-domain.com

# Rate Limiting Configuration
SEC_RATE_LIMIT_REQUESTS_PER_SECOND=10
SEC_REQUEST_DELAY_MS=120

# Evidence Chain Configuration
EVIDENCE_CHAIN_ENABLED=true
CRYPTOGRAPHIC_HASHING=SHA-256

# Deployment Environment
ENVIRONMENT=production
DEBUG=false

# Database Configuration
POSTGRES_USER=forensic_user
POSTGRES_PASSWORD=

# MinIO Configuration
MINIO_ROOT_USER=forensic_admin
MINIO_ROOT_PASSWORD=

# API Keys
SEC_EDGAR_USER_AGENT=JLAW Forensics System contact@your-domain.com

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
