"""
MODULE 4: Earnings Event Correlator
Detects insider trading activity within suspicious proximity to earnings announcements
and other material events (M&A, product launches, etc.)
"""

from datetime import datetime, timedelta
from typing import List, Dict, Optional


def is_within_earnings_window(txn_date, earnings_dates, window_days=14):
    """
    Check if transaction falls within earnings blackout window

    Standard blackout: 14 days before earnings through 1 day after

    Args:
        txn_date: Transaction date (YYYY-MM-DD string)
        earnings_dates: List of earnings announcement dates (YYYY-MM-DD strings)
        window_days: Number of days before/after earnings to flag (default 14)

    Returns:
        Boolean indicating if within earnings window
    """
    try:
        txn_dt = datetime.strptime(txn_date, "%Y-%m-%d")

        for event_date in earnings_dates:
            event_dt = datetime.strptime(event_date, "%Y-%m-%d")

            # Calculate days difference
            days_diff = (txn_dt - event_dt).days

            # Check if within window (before or after)
            if abs(days_diff) <= window_days:
                return True

        return False

    except (ValueError, TypeError):
        return False


def analyze_earnings_proximity(txn_date, earnings_dates, window_days=14):
    """
    Detailed analysis of transaction proximity to earnings

    Args:
        txn_date: Transaction date (YYYY-MM-DD string)
        earnings_dates: List of earnings announcement dates
        window_days: Days before/after to consider

    Returns:
        Detailed proximity analysis
    """
    try:
        txn_dt = datetime.strptime(txn_date, "%Y-%m-%d")

        closest_event = None
        closest_days = float('inf')

        for event_date in earnings_dates:
            event_dt = datetime.strptime(event_date, "%Y-%m-%d")
            days_diff = (txn_dt - event_dt).days

            if abs(days_diff) < abs(closest_days):
                closest_days = days_diff
                closest_event = event_date

        if closest_event and abs(closest_days) <= window_days:
            # Determine timing
            if closest_days < 0:
                timing = "BEFORE"
                severity = "CRITICAL" if closest_days >= -7 else "HIGH"
                flag_type = "PRE_EARNINGS_TRADING"
            elif closest_days == 0:
                timing = "ON"
                severity = "CRITICAL"
                flag_type = "EARNINGS_DAY_TRADING"
            else:
                timing = "AFTER"
                severity = "MEDIUM" if closest_days <= 2 else "LOW"
                flag_type = "POST_EARNINGS_TRADING"

            return {
                "within_window": True,
                "closest_event": closest_event,
                "days_difference": closest_days,
                "timing": timing,
                "severity": severity,
                "flag_type": flag_type,
                "description": f"Transaction {abs(closest_days)} days {timing.lower()} earnings on {closest_event}",
                "recommendation": "Verify no access to preliminary financial results" if timing == "BEFORE" else "Review for selective disclosure violations"
            }

        return {"within_window": False}

    except (ValueError, TypeError):
        return {"within_window": False, "error": "Date parsing failed"}


def detect_clustered_trading(transactions, earnings_dates, cluster_window=7):
    """
    Detect clustering of insider transactions around earnings events

    Args:
        transactions: List of transaction dictionaries
        earnings_dates: List of earnings dates
        cluster_window: Days around earnings to consider a cluster

    Returns:
        Cluster analysis
    """
    clusters = []

    for earnings_date in earnings_dates:
        try:
            earnings_dt = datetime.strptime(earnings_date, "%Y-%m-%d")

            # Find transactions within cluster window
            clustered_txns = []

            for txn in transactions:
                txn_date = txn.get('transaction_date')
                if not txn_date:
                    continue

                txn_dt = datetime.strptime(txn_date, "%Y-%m-%d")
                days_diff = (txn_dt - earnings_dt).days

                if -cluster_window <= days_diff <= cluster_window:
                    clustered_txns.append({
                        "transaction": txn,
                        "days_from_earnings": days_diff
                    })

            if len(clustered_txns) >= 2:
                # Multiple transactions near same earnings event
                total_shares = 0
                total_value = 0

                for ct in clustered_txns:
                    t = ct["transaction"]
                    try:
                        shares = float(str(t.get('shares', '0')).replace(',', ''))
                        price = float(str(t.get('price_per_share', '0')).replace('$', '').replace(',', ''))
                        total_shares += shares
                        total_value += shares * price
                    except (ValueError, TypeError):
                        pass

                clusters.append({
                    "earnings_date": earnings_date,
                    "transaction_count": len(clustered_txns),
                    "total_shares": int(total_shares),
                    "total_value": total_value,
                    "severity": "HIGH" if len(clustered_txns) >= 3 else "MEDIUM",
                    "flag": "EARNINGS_CLUSTER_TRADING",
                    "description": f"{len(clustered_txns)} transactions within {cluster_window} days of earnings",
                    "recommendation": "Investigate for coordinated insider activity or MNPI abuse"
                })

        except (ValueError, TypeError):
            continue

    return clusters


def load_earnings_calendar(file_path: Optional[str] = None, ticker: str = "NKE"):
    """
    Load earnings calendar from JSON file or return default Nike dates

    Args:
        file_path: Path to earnings_calendar.json
        ticker: Stock ticker symbol

    Returns:
        List of earnings dates
    """
    # Default Nike earnings dates for 2019 (fiscal year quarters)
    default_nike_2019 = [
        "2019-09-24",  # Q1 FY2020
        "2019-12-19",  # Q2 FY2020
        "2020-03-24",  # Q3 FY2020 (would be relevant for Q4 2019 trades)
    ]

    if file_path:
        try:
            import json
            with open(file_path, 'r') as f:
                calendar = json.load(f)
                return calendar.get(ticker, default_nike_2019)
        except (FileNotFoundError, json.JSONDecodeError):
            pass

    return default_nike_2019


def correlate_all_transactions(transactions, earnings_dates, window_days=14):
    """
    Correlate all transactions with earnings events

    Args:
        transactions: List of all transactions
        earnings_dates: List of earnings dates
        window_days: Window around earnings to flag

    Returns:
        Complete correlation analysis
    """
    correlations = {
        "total_transactions": len(transactions),
        "within_window": 0,
        "flagged_transactions": [],
        "clusters": [],
        "overall_risk": 0.0
    }

    # Analyze each transaction
    for txn in transactions:
        txn_date = txn.get('transaction_date')
        if not txn_date:
            continue

        proximity = analyze_earnings_proximity(txn_date, earnings_dates, window_days)

        if proximity.get('within_window'):
            correlations["within_window"] += 1

            flagged = {
                "transaction": txn,
                "proximity_analysis": proximity
            }

            correlations["flagged_transactions"].append(flagged)

            # Add to risk score based on severity
            if proximity['severity'] == 'CRITICAL':
                correlations["overall_risk"] += 0.3
            elif proximity['severity'] == 'HIGH':
                correlations["overall_risk"] += 0.2
            elif proximity['severity'] == 'MEDIUM':
                correlations["overall_risk"] += 0.1

    # Detect clusters
    correlations["clusters"] = detect_clustered_trading(transactions, earnings_dates)

    # Add cluster risk
    correlations["overall_risk"] += len(correlations["clusters"]) * 0.2

    # Cap at 1.0
    correlations["overall_risk"] = min(round(correlations["overall_risk"], 2), 1.0)

    return correlations


def check_material_event_proximity(txn_date, material_events, event_type="M&A"):
    """
    Check proximity to material events (M&A, product launches, etc.)

    Args:
        txn_date: Transaction date
        material_events: List of material event dates
        event_type: Type of event (M&A, Product Launch, Restructuring, etc.)

    Returns:
        Proximity check result
    """
    try:
        txn_dt = datetime.strptime(txn_date, "%Y-%m-%d")

        for event_date in material_events:
            event_dt = datetime.strptime(event_date, "%Y-%m-%d")
            days_diff = (txn_dt - event_dt).days

            # Flag if within 30 days before material event announcement
            if -30 <= days_diff < 0:
                return {
                    "flagged": True,
                    "event_type": event_type,
                    "event_date": event_date,
                    "days_before_event": abs(days_diff),
                    "severity": "CRITICAL" if days_diff >= -7 else "HIGH",
                    "description": f"Transaction {abs(days_diff)} days before {event_type} announcement",
                    "recommendation": f"Investigate for {event_type}-related MNPI abuse"
                }

        return {"flagged": False}

    except (ValueError, TypeError):
        return {"flagged": False, "error": "Date parsing failed"}

