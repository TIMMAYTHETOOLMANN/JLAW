# JARVIS:LAW Optimized Multi-Stage Dockerfile
# This builds faster by using pre-built wheels and layer caching

# Stage 1: Build dependencies
FROM python:3.11-slim as builder

WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ build-essential \
    && rm -rf /var/lib/apt/lists/*

# Upgrade pip
RUN pip install --no-cache-dir --upgrade pip setuptools wheel

# Install core packages and create wheels
RUN pip wheel --no-cache-dir --wheel-dir /wheels \
    flask flask-cors waitress \
    numpy pandas scikit-learn \
    matplotlib seaborn \
    openai httpx beautifulsoup4 lxml \
    python-dotenv litellm

# Stage 2: Runtime image
FROM python:3.11-slim

WORKDIR /app

# Install minimal runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Copy wheels from builder
COPY --from=builder /wheels /wheels

# Install from wheels (much faster)
RUN pip install --no-cache-dir --no-index --find-links=/wheels \
    flask flask-cors waitress \
    numpy pandas scikit-learn \
    matplotlib seaborn \
    openai httpx beautifulsoup4 lxml \
    python-dotenv litellm \
    && rm -rf /wheels

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# Copy application code
COPY . .

# Create output directories
RUN mkdir -p forensic_exports web_frontend

EXPOSE 5000

# Simple healthcheck
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import sys; sys.exit(0)" || exit 1

CMD ["python", "production_waitress.py"]

